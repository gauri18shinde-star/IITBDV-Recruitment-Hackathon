<?xml version="1.0"?>
<robot name="racecar_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_sim)/urdf/robot.gazebo" />
<xacro:include filename="$(find robot_sim)/urdf/colour.xacro" />


<link name="base_footprint"></link>

<joint name="base_footprint_joint" type="fixed">
  <origin xyz="0 0 0" rpy="0 0 0" />
  <parent link="base_footprint"/>
  <child link="base_link" />
</joint>


<!-- CHASSIS -->
<link name="base_link">
  <visual>
    <geometry>
      <box size="0.6 0.35 0.1"/>
    </geometry>
    <material name="pink"/>
  </visual>

  <collision>
    <geometry>
      <box size="0.6 0.35 0.1"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="10"/>
    <inertia ixx="0.11" ixy="0" ixz="0"
             iyy="0.3" iyz="0"
             izz="0.4"/>
  </inertial>
</link>


<!-- WHEEL JOINTS -->

<!---
<joint name="front_left_joint" type="continuous">
  <parent link="base_link"/>
  <child link="front_left_wheel"/>
  <origin xyz="0.2 0.18 -0.05"/>
  <axis xyz="0 1 0"/>
</joint>

-->

<!-- SENSOR MOUNT -->
<joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="scan_link"/>
  <origin xyz="0.25 0 0.1"/>
</joint>


<joint type="continuous" name="front_left_joint">
  <origin xyz="0.2 0.18 -0.05" rpy="0 0 0"/>
  <child link="front_left_wheel"/>
  <parent link="base_link"/>
  <axis xyz="0 1 0" rpy="0 0 0"/>
  <limit effort="100" velocity="10"/>
  <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint type="continuous" name="front_right_joint">
  <origin xyz="0.2 -0.18 -0.05" rpy="0 0 0"/>
  <child link="front_right_wheel"/>
  <parent link="base_link"/>
  <axis xyz="0 1 0" rpy="0 0 0"/>
  <limit effort="100" velocity="10"/>
  <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint type="continuous" name="rear_left_joint">
  <origin xyz="-0.2 0.18 -0.05" rpy="0 0 0"/>
  <child link="rear_left_wheel"/>
  <parent link="base_link"/>
  <axis xyz="0 1 0" rpy="0 0 0"/>
  <limit effort="100" velocity="10"/>
  <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint type="continuous" name="rear_right_joint">
  <origin xyz="-0.2 -0.18 -0.05" rpy="0 0 0"/>
  <child link="rear_right_wheel"/>
  <parent link="base_link"/>
  <axis xyz="0 1 0" rpy="0 0 0"/>
  <limit effort="100" velocity="10"/>
  <dynamics damping="1.0" friction="1.0"/>
</joint>

<!-- WHEELS -->
<link name="front_left_wheel">
  <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia
          ixx="0.014" ixy="0" ixz="0"
          iyy="0.014" iyz="0"
          izz="0.025"
      />
    </inertial>

  <visual>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
    <material name="black"/>
  </visual>

  <collision>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
  </collision>
</link>

<link name="front_right_wheel">

  <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia
          ixx="0.014" ixy="0" ixz="0"
          iyy="0.014" iyz="0"
          izz="0.025"
      />
    </inertial>
  <visual>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
    <material name="black"/>
  </visual>
    <collision>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
  </collision>
</link>

<link name="rear_left_wheel">
  <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia
          ixx="0.014" ixy="0" ixz="0"
          iyy="0.014" iyz="0"
          izz="0.025"
      />
    </inertial>
  <visual>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
    <material name="black"/>
  </visual>
    <collision>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
  </collision>
</link>

<link name="rear_right_wheel">
  <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia
          ixx="0.014" ixy="0" ixz="0"
          iyy="0.014" iyz="0"
          izz="0.025"
      />
    </inertial>
  <visual>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
    <material name="black"/>
  </visual>
    <collision>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.07" length="0.05"/>
    </geometry>
  </collision>
</link>


<!-- SENSOR -->
<link name="scan_link">
  <visual>
    <geometry>
      <cylinder radius="0.05" length="0.04"/>
    </geometry>
    <material name="purple"/>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.05" length="0.04"/>
    </geometry>
  </collision>
</link>



</robot>